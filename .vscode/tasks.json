{
   "version": "2.0.0",
   "tasks": [
      {
         "label": "build tungsten",
         "type": "shell",
         "command": "tungsten",
         "args": [
            "${file}"
         ],
         "group": {
            "kind": "build",
            "isDefault": true
         },
         "problemMatcher": []
      },
      {
         "label": "Run Tungsten",
         "type": "shell",
         "command": "${fileBasenameNoExtension}.exe",
         "options": {
            "cwd": "${fileDirname}"
         },
         "dependsOn": "build tungsten",
         "group": "build",
         "problemMatcher": [],
         "presentation": {
            "echo": true,
            "reveal": "always",
            "panel": "shared"
         }
      }
   ]
}